<script>
// ============================================
// CONFIGURACIÓN GLOBAL
// ============================================
window.DASHBOARD_CONFIG = {
  SHEET_URL: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vTCYVQkqg8qgPq-OMKINCAlI88Du4-GkjXnC13T0ZoAQolXbWayDCnvax0S_aydd6nGsoKqCtb7DsOS/pub?gid=0&single=true&output=csv',
  columns: {
    empresa: 'EMPRESA', fecha: 'FECHA', tipoCuenta: 'TIPO CUENTA', tipoGasto: 'TIPO DE GASTOS',
    categoria: 'CATEGORIA', asiento: 'ASIENTO', descripcion: 'DESCRIPCION', monto: 'MONTO',
    totalBs: 'TOTAL Bs ($)', totalUsd: 'TOTAL $', totalGral: 'TOTAL GRAL', implicita: '$  IMPLICITA'
  },
  monthMap: { 'enero':'Enero','febrero':'Febrero','marzo':'Marzo','abril':'Abril','mayo':'Mayo','junio':'Junio','julio':'Julio','agosto':'Agosto','septiembre':'Septiembre','octubre':'Octubre','noviembre':'Noviembre','diciembre':'Diciembre' }
};

window.filters = { company: 'ALL', expenseType: 'ALL', category: 'ALL', asiento: 'ALL', dateStart: null, dateEnd: null };
window.rawData = [];
window.chartInstances = {};

// ✅ FORMATO VENEZOLANO: USD 151.293,00 (punto para miles, coma para decimales)
window.formatterUSD = new Intl.NumberFormat('es-VE', { 
  style: 'currency', 
  currency: 'USD', 
  minimumFractionDigits: 2,
  maximumFractionDigits: 2 
});

// ✅ Función auxiliar para redondeo financiero seguro
function round2(num) {
  return Math.round((num + Number.EPSILON) * 100) / 100;
}

// ✅ FUNCIÓN INTELIGENTE PARA LEER NÚMEROS (Maneja 1.000,00 y 1,000.00)
function parseLocaleNumber(string) {
    if (!string) return 0;
    var s = string.toString().replace(/[$€£¥\s]/g, '').trim();
    if (!s) return 0;

    var lastDot = s.lastIndexOf('.');
    var lastComma = s.lastIndexOf(',');

    if (lastDot > -1 && lastComma > -1) {
        if (lastComma > lastDot) {
            return parseFloat(s.replace(/\./g, '').replace(',', '.'));
        } else {
            return parseFloat(s.replace(/,/g, ''));
        }
    } else if (lastComma > -1) {
        var parts = s.split(',');
        if (parts.length > 2 || (parts[1] && parts[1].length === 3)) {
            return parseFloat(s.replace(/,/g, ''));
        } else {
            return parseFloat(s.replace(',', '.'));
        }
    }
    return parseFloat(s);
}

// ============================================
// PARSING DE CSV
// ============================================
function parseCSVLine(line) {
  var result = [], current = { val: '', inQuotes: false };
  for (var i = 0; i < line.length; i++) {
    var c = line[i], next = line[i+1];
    if (c === '"') {
      if (current.inQuotes && next === '"') { current.val += '"'; i++; }
      else current.inQuotes = !current.inQuotes;
    } else if (c === ',' && !current.inQuotes) {
      result.push(current.val); current.val = '';
    } else current.val += c;
  }
  result.push(current.val);
  return result.map(v => v.trim());
}

function parseCSV(text) {
  var lines = text.trim().split(/\r?\n/).filter(l => l.trim());
  if (lines.length < 2) return [];
  var headers = parseCSVLine(lines[0]);
  
  return lines.slice(1).map(line => {
    var values = parseCSVLine(line);
    var obj = {};
    headers.forEach((h, i) => {
      var v = values[i] || '';
      if (['MONTO', 'TOTAL Bs ($)', 'TOTAL $', 'TOTAL GRAL', '$  IMPLICITA'].includes(h)) {
        v = parseLocaleNumber(v);
        v = isNaN(v) ? 0 : round2(v);
      }
      obj[h] = v;
    });
    if (obj['FECHA']) {
      var dateParts = obj['FECHA'].split('/');
      if (dateParts.length === 3) {
        obj._dateObj = new Date(dateParts[2], dateParts[1] - 1, dateParts[0]);
        obj._monthName = window.DASHBOARD_CONFIG.monthMap[dateParts[1].toLowerCase()] || dateParts[1];
        obj._monthNum = parseInt(dateParts[1]);
        obj._year = parseInt(dateParts[2]);
      }
    }
    return obj;
  }).filter(row => row._dateObj);
}

// ============================================
// FILTROS Y OPCIONES
// ============================================
function populateFilterOptions() {
  var companies = [...new Set(rawData.map(r => r['EMPRESA']).filter(Boolean))].sort();
  var expenseTypes = [...new Set(rawData.map(r => r['TIPO DE GASTOS']).filter(Boolean))].sort();
  var categories = [...new Set(rawData.map(r => r['CATEGORIA']).filter(Boolean))].sort();
  
  var companySel = document.getElementById('companyFilter');
  var expenseSel = document.getElementById('expenseTypeFilter');
  var categorySel = document.getElementById('categoryFilter');
  
  companies.forEach(c => { if(c) companySel.add(new Option(c, c)); });
  expenseTypes.forEach(t => { if(t) expenseSel.add(new Option(t, t)); });
  categories.forEach(cat => { if(cat) categorySel.add(new Option(cat, cat)); });
  
  // Inicializar asientos con todos
  updateAsientoOptions('ALL');
}

// ✅ FUNCIÓN PARA ACTUALIZAR ASIENTOS SEGÚN CATEGORÍA
function updateAsientoOptions(categoryFilter) {
  var asientoSel = document.getElementById('asientoFilter');
  var currentSelection = window.filters.asiento;
  
  // Guardar el valor actual y limpiar
  asientoSel.innerHTML = '<option value="ALL">Todos</option>';
  
  // Obtener asientos únicos basados en la categoría filtrada
  var asientos;
  if (categoryFilter === 'ALL') {
    // Si es "Todas" las categorías, mostrar todos los asientos
    asientos = [...new Set(rawData.map(r => r['ASIENTO']).filter(Boolean))].sort();
  } else {
    // Filtrar por categoría específica
    var filteredData = rawData.filter(r => r['CATEGORIA'] === categoryFilter);
    asientos = [...new Set(filteredData.map(r => r['ASIENTO']).filter(Boolean))].sort();
  }
  
  // Agregar opciones de asientos
  asientos.forEach(a => { 
    if(a) asientoSel.add(new Option(a, a)); 
  });
  
  // Restaurar selección si es válida, sino seleccionar "Todos"
  if (currentSelection && currentSelection !== 'ALL' && asientos.includes(currentSelection)) {
    asientoSel.value = currentSelection;
  } else {
    window.filters.asiento = 'ALL';
    asientoSel.value = 'ALL';
  }
}

function getFilteredData() {
  return rawData.filter(row => {
    if (window.filters.company !== 'ALL' && row['EMPRESA'] !== window.filters.company) return false;
    if (window.filters.expenseType !== 'ALL' && row['TIPO DE GASTOS'] !== window.filters.expenseType) return false;
    if (window.filters.category !== 'ALL' && row['CATEGORIA'] !== window.filters.category) return false;
    if (window.filters.asiento !== 'ALL' && row['ASIENTO'] !== window.filters.asiento) return false;
    if (window.filters.dateStart && row._dateObj < new Date(window.filters.dateStart)) return false;
    if (window.filters.dateEnd && row._dateObj > new Date(window.filters.dateEnd + 'T23:59:59')) return false;
    return true;
  });
}

// ============================================
// AGREGACIÓN DE DATOS
// ============================================
function aggregateData(data) {
  var byMonth = {}, byCategory = {}, byType = {}, byCompany = {};
  
  data.forEach(row => {
    var mKey = row._monthName + ' ' + row._year;
    if (!byMonth[mKey]) byMonth[mKey] = { label: mKey, monthNum: row._monthNum, year: row._year, total: 0, implicita: 0, bs: 0 };
    
    byMonth[mKey].total = round2(byMonth[mKey].total + (row['TOTAL $'] || 0));
    byMonth[mKey].implicita = round2(byMonth[mKey].implicita + (row['$  IMPLICITA'] || 0));
    byMonth[mKey].bs = round2(byMonth[mKey].bs + (row['TOTAL Bs ($)'] || 0));
    
    var cat = row['CATEGORIA'] || 'Sin categoría';
    if (!byCategory[cat]) byCategory[cat] = { name: cat, value: 0 };
    byCategory[cat].value = round2(byCategory[cat].value + (row['$  IMPLICITA'] || 0));
    
    var type = row['TIPO DE GASTOS'] || 'Sin tipo';
    if (!byType[type]) byType[type] = { name: type, value: 0 };
    byType[type].value = round2(byType[type].value + (row['$  IMPLICITA'] || 0));
    
    var comp = row['EMPRESA'] || 'Sin empresa';
    if (!byCompany[comp]) byCompany[comp] = { name: comp, value: 0 };
    byCompany[comp].value = round2(byCompany[comp].value + (row['$  IMPLICITA'] || 0));
  });
  
  return {
    byMonth: Object.values(byMonth).sort((a,b) => (a.year*100+a.monthNum) - (b.year*100+b.monthNum)),
    byCategory: Object.values(byCategory).sort((a,b) => b.value - a.value).slice(0, 8),
    byType: Object.values(byType).sort((a,b) => b.value - a.value),
    byCompany: Object.values(byCompany).sort((a,b) => b.value - a.value)
  };
}

// ============================================
// CÁLCULO DE KPIs
// ============================================
function calculateKPIs(data) {
  var totalImplicita = data.reduce((sum, r) => sum + (r['$  IMPLICITA'] || 0), 0);
  var totalGral = data.reduce((sum, r) => sum + (r['TOTAL GRAL'] || 0), 0);
  var totalBs = data.reduce((sum, r) => sum + (r['TOTAL Bs ($)'] || 0), 0);
  
  var diferencia = totalGral - totalImplicita;
  var porcentajeBs = totalGral > 0 ? (totalBs / totalGral) * 100 : 0;
  
  return { 
    totalImplicita: round2(totalImplicita),
    totalGral: round2(totalGral),
    diferencia: round2(diferencia),
    porcentajeBs: round2(porcentajeBs),
    totalBs: round2(totalBs)
  };
}

// ============================================
// ACTUALIZACIÓN DE KPIs
// ============================================
function updateKPIs(kpis) {
  document.getElementById('kpi-implicita').textContent = formatterUSD.format(kpis.totalImplicita);
  document.getElementById('kpi-totalGral').textContent = formatterUSD.format(kpis.totalGral);
  
  var diffEl = document.getElementById('kpi-diferencia');
  diffEl.textContent = formatterUSD.format(kpis.diferencia);
  diffEl.className = 'text-2xl font-black ' + (kpis.diferencia >= 0 ? 'text-emerald-400' : 'text-red-400');
  
  var pctEl = document.getElementById('kpi-porcentajeBs');
  pctEl.textContent = kpis.porcentajeBs.toFixed(2) + '%';
  pctEl.className = 'text-2xl font-black ' + (kpis.porcentajeBs >= 50 ? 'text-emerald-600' : 'text-amber-600');
}

// ============================================
// RENDERIZADO DE TABLA
// ============================================
function renderTable(data) {
  var tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';
  document.getElementById('tableCount').textContent = data.length + ' registros';
  
  if (data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" class="text-center py-8 text-slate-500">No hay datos para mostrar con los filtros aplicados</td></tr>';
    return;
  }
  
  var sorted = data.slice().sort((a,b) => b._dateObj - a._dateObj).slice(0, 100);
  sorted.forEach(row => {
    var tr = document.createElement('tr');
    var tipoBadge = row['TIPO DE GASTOS']?.includes('Egreso') ? 'badge-egreso' : row['TIPO DE GASTOS']?.includes('Ingreso') ? 'badge-ingreso' : 'badge-ajuste';
    tr.innerHTML = 
      '<td class="font-medium">' + (row['FECHA'] || '-') + '</td>' +
      '<td>' + (row['EMPRESA'] || '-') + '</td>' +
      '<td><span class="badge ' + tipoBadge + '">' + (row['TIPO CUENTA'] || '-') + '</span></td>' +
      '<td>' + (row['TIPO DE GASTOS'] || '-') + '</td>' +
      '<td>' + (row['CATEGORIA'] || '-') + '</td>' +
      '<td class="font-mono text-xs">' + (row['ASIENTO'] || '-') + '</td>' +
      '<td class="max-w-xs truncate" title="' + (row['DESCRIPCION'] || '') + '">' + (row['DESCRIPCION'] || '-') + '</td>' +
      '<td class="text-right text-slate-600">' + formatterUSD.format(row['MONTO'] || 0) + '</td>' +
      '<td class="text-right font-semibold">' + formatterUSD.format(row['TOTAL $'] || 0) + '</td>' +
      '<td class="text-right font-bold text-primary">' + formatterUSD.format(row['$  IMPLICITA'] || 0) + '</td>';
    tbody.appendChild(tr);
  });
}

// ============================================
// GRÁFICOS
// ============================================
function createBarChart(data) {
  var ctx = document.getElementById('barChart');
  if (!ctx) return;
  if (window.chartInstances.bar) window.chartInstances.bar.destroy();
  
  var labels = data.map(d => d.label);
  var values = data.map(d => d.total);
  var implicit = data.map(d => d.implicita);
  
  window.chartInstances.bar = new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Total $', data: values, backgroundColor: '#D32F2F', borderRadius: 4 },
        { label: '$ Implícita', data: implicit, backgroundColor: '#fbbf24', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { 
        legend: { position: 'top', labels: { usePointStyle: true } }, 
        tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + formatterUSD.format(ctx.parsed.y) } } 
      },
      scales: { 
        x: { grid: { display: false } }, 
        y: { beginAtZero: true, ticks: { callback: v => '$' + (v/1000).toFixed(1) + 'k' } } 
      }
    }
  });
}

function createPieChart(data, chartId, legendId, colors) {
  var ctx = document.getElementById(chartId);
  if (!ctx) return;
  if (window.chartInstances[chartId]) window.chartInstances[chartId].destroy();
  
  var labels = data.map(d => d.name);
  var values = data.map(d => d.value);
  var bgColors = data.map((d,i) => colors[i % colors.length]);
  
  if (legendId) {
    document.getElementById(legendId).innerHTML = data.map((d,i) => 
      '<div class="flex items-center text-xs"><div class="w-3 h-3 rounded-full mr-2" style="background:' + bgColors[i] + '"></div>' + d.name + '</div>'
    ).join('');
  }
  
  window.chartInstances[chartId] = new Chart(ctx.getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: labels,
      datasets: [{ data: values, backgroundColor: bgColors, borderWidth: 0, spacing: 4, cutout: '65%' }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { 
        legend: { display: false }, 
        tooltip: { 
          callbacks: { 
            label: ctx => { 
              var total = ctx.dataset.data.reduce((a,b) => a+b, 0); 
              var pct = total > 0 ? ((ctx.parsed/total)*100).toFixed(1) : 0; 
              return ctx.label + ': ' + formatterUSD.format(ctx.parsed) + ' (' + pct + '%)'; 
            } 
          } 
        } 
      }
    }
  });
}

function createCompanyChart(data) {
  var ctx = document.getElementById('companyChart');
  if (!ctx) return;
  if (window.chartInstances.companyChart) window.chartInstances.companyChart.destroy();
  
  var labels = data.map(d => d.name);
  var values = data.map(d => d.value);
  
  window.chartInstances.companyChart = new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{ label: 'Gastos $', data: values, backgroundColor: '#0f172a', borderRadius: 4 }]
    },
    options: {
      indexAxis: 'y', 
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { 
        x: { beginAtZero: true, ticks: { callback: v => '$' + (v/1000).toFixed(1) + 'k' } }, 
        y: { grid: { display: false } } 
      }
    }
  });
}

// ============================================
// RENDERIZADO PRINCIPAL
// ============================================
function renderDashboard() {
  var filtered = getFilteredData();
  var aggregated = aggregateData(filtered);
  var kpis = calculateKPIs(filtered);
  
  updateKPIs(kpis);
  renderTable(filtered);
  
  if (aggregated.byMonth.length > 0) { 
    createBarChart(aggregated.byMonth); 
    document.getElementById('chartPeriodLabel').textContent = aggregated.byMonth[0].label + ' → ' + aggregated.byMonth[aggregated.byMonth.length-1].label; 
  }
  
  var pieColors = ['#D32F2F', '#0f172a', '#10b981', '#f59e0b', '#3b82f6', '#8b5cf6', '#ec4899', '#6366f1'];
  if (aggregated.byCategory.length > 0) createPieChart(aggregated.byCategory, 'pieChart', 'pieLegend', pieColors);
  if (aggregated.byType.length > 0) createPieChart(aggregated.byType, 'doughnutChart', 'doughnutLegend', ['#0f172a', '#64748b', '#94a3b8', '#cbd5e1']);
  if (aggregated.byCompany.length > 0) createCompanyChart(aggregated.byCompany);
  
  document.getElementById('debugInfo').innerHTML = 
    '<p>📊 Registros cargados: <strong>' + rawData.length + '</strong></p>' +
    '<p>🔍 Registros filtrados: <strong>' + filtered.length + '</strong></p>' +
    '<p>📅 Rango: ' + (window.filters.dateStart || 'Inicio') + ' → ' + (window.filters.dateEnd || 'Fin') + '</p>';
}

// ============================================
// EVENT LISTENERS
// ============================================
function setupEventListeners() {
  document.getElementById('companyFilter').addEventListener('change', e => { 
    window.filters.company = e.target.value; 
    renderDashboard(); 
  });
  
  document.getElementById('expenseTypeFilter').addEventListener('change', e => { 
    window.filters.expenseType = e.target.value; 
    renderDashboard(); 
  });
  
  // ✅ EVENTO PARA CATEGORÍA - Actualiza asientos disponibles
  document.getElementById('categoryFilter').addEventListener('change', e => { 
    window.filters.category = e.target.value; 
    updateAsientoOptions(window.filters.category); // Actualizar asientos según categoría
    renderDashboard(); 
  });
  
  document.getElementById('asientoFilter').addEventListener('change', e => { 
    window.filters.asiento = e.target.value; 
    renderDashboard(); 
  });
  
  document.getElementById('btnApplyDateFilter').addEventListener('click', () => { 
    window.filters.dateStart = document.getElementById('dateStart').value || null; 
    window.filters.dateEnd = document.getElementById('dateEnd').value || null; 
    document.getElementById('dateFilterHint').classList.toggle('hidden', !window.filters.dateStart && !window.filters.dateEnd); 
    renderDashboard(); 
  });
  
  document.getElementById('btnClearFilters').addEventListener('click', () => { 
    window.filters = { company: 'ALL', expenseType: 'ALL', category: 'ALL', asiento: 'ALL', dateStart: null, dateEnd: null }; 
    document.getElementById('companyFilter').value = 'ALL'; 
    document.getElementById('expenseTypeFilter').value = 'ALL'; 
    document.getElementById('categoryFilter').value = 'ALL'; 
    document.getElementById('asientoFilter').value = 'ALL';
    document.getElementById('dateStart').value = ''; 
    document.getElementById('dateEnd').value = ''; 
    document.getElementById('dateFilterHint').classList.add('hidden'); 
    updateAsientoOptions('ALL'); // Restaurar todos los asientos
    renderDashboard(); 
  });
}

// ============================================
// CARGA DE DATOS
// ============================================
async function loadData() {
  var statusEl = document.getElementById('connectionStatus');
  try {
    statusEl.textContent = '🔄 Cargando datos...';
    var response = await fetch(window.DASHBOARD_CONFIG.SHEET_URL);
    if (!response.ok) throw new Error('HTTP ' + response.status);
    var csvText = await response.text();
    rawData = parseCSV(csvText);
    
    if (rawData.length === 0) throw new Error('Sin datos válidos');
    
    populateFilterOptions();
    setupEventListeners();
    
    statusEl.textContent = '✅ Actualizado: ' + new Date().toLocaleTimeString('es-VE');
    statusEl.className = 'text-center text-sm text-emerald-600';
    document.getElementById('dataStatus').textContent = 'Datos actualizados';
    
    renderDashboard();
  } catch (error) {
    console.error('❌ Error:', error);
    statusEl.textContent = '⚠️ Error: ' + error.message;
    statusEl.className = 'text-center text-sm text-amber-600';
    document.getElementById('debugInfo').innerHTML = '<p class="text-red-600">Error: ' + error.message + '</p>';
  }
}

// ============================================
// INICIALIZACIÓN
// ============================================
if (document.readyState === 'loading') { 
  document.addEventListener('DOMContentLoaded', loadData); 
} else { 
  loadData(); 
}
</script>
