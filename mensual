<script>
(function() {
  const CONFIG = {
    SHEET_URL: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQNYg-Dv3x9VcaKF78jubHC9lfkqPlnQp9WZBh30X932tJVbk8d3tfx5UM6dCvIMruy8Bc7WwwlqL29/pub?output=csv'
  };

  let rawData = [];
  let selectedCompany = 'ALL';
  let monthStartFilter = 1;
  let monthEndFilter = 12;
  
  let lineChartInstance = null;
  let profitChartInstance = null;

  const monthNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
  const formatterUSD = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2 });

  function parseCSVLine(line) {
    const result = [];
    let current = '';
    let inQuotes = false;
    for (let i = 0; i < line.length; i++) {
      const c = line[i];
      if (c === '"') inQuotes = !inQuotes;
      else if (c === ',' && !inQuotes) { result.push(current.trim()); current = ''; }
      else current += c;
    }
    result.push(current.trim());
    return result;
  }

  function parseCSV(text) {
    const lines = text.trim().split(/\r?\n/).filter(l => l.trim());
    if (lines.length < 2) return [];
    const headers = parseCSVLine(lines[0]);
    return lines.slice(1).map(line => {
      const values = parseCSVLine(line);
      const obj = {};
      headers.forEach((h, i) => {
        let v = values[i] || '';
        if (v && !isNaN(v) && !isNaN(parseFloat(v)) && v.indexOf(',') === -1) v = parseFloat(v);
        if (typeof v === 'string' && v.indexOf(',') > -1 && !isNaN(parseFloat(v.replace(',', '.')))) v = parseFloat(v.replace(',', '.'));
        obj[h] = v;
      });
      return obj;
    });
  }

  async function loadAndProcessData() {
    const statusEl = document.getElementById('connectionStatus');
    const debugEl = document.getElementById('debugInfo');
    try {
      statusEl.textContent = '🔄 Cargando datos financieros...';
      const response = await fetch(CONFIG.SHEET_URL);
      if (!response.ok) throw new Error('HTTP ' + response.status);
      const csvText = await response.text();
      const data = parseCSV(csvText);
      
      rawData = data.filter(row => {
        const mes = parseInt(row.Mes);
        if (isNaN(mes) || mes < 1 || mes > 12) return false;
        row.mesNum = mes;
        row.mesNombre = monthNames[mes - 1];
        row.ventasImp = parseFloat(row['$  (IMP)']) || 0;
        row.ventasBcv = parseFloat(row['$  (BCV)']) || 0;
        return true;
      });
      
      debugEl.innerHTML = `<p>✅ <strong>${rawData.length}</strong> registros cargados</p><p class="mt-1">Empresas: RCH MCY, RCH BQ, RCH ONLINE<br>Tipos: VENTAS, COSTOS VTA, GASTOS TIENDA, GASTOS EXTRAS, GASTOS PERSONALES, INTERESES</p>`;
      statusEl.textContent = '✅ Datos actualizados: ' + new Date().toLocaleTimeString('es-VE');
      document.getElementById('dataStatus').textContent = 'Datos financieros cargados';
      renderDashboard();
    } catch (error) {
      console.error(error);
      statusEl.textContent = '⚠️ Error: ' + error.message;
      debugEl.innerHTML = `<p class="text-red-600">Error cargando datos. Verifica la hoja de cálculo.</p>`;
      rawData = [];
      renderDashboard();
    }
  }

  function filterData() {
    let filtered = [...rawData];
    if (selectedCompany !== 'ALL') {
      filtered = filtered.filter(row => row.Empresa === selectedCompany);
    }
    filtered = filtered.filter(row => row.mesNum >= monthStartFilter && row.mesNum <= monthEndFilter);
    return filtered;
  }

  function aggregateMonthlyData(filteredData) {
    const monthly = {};
    for (let m = monthStartFilter; m <= monthEndFilter; m++) {
      monthly[m] = {
        mesNum: m,
        mesNombre: monthNames[m-1],
        ventasImp: 0, ventasBcv: 0, costoVenta: 0, gastosTienda: 0,
        gastosExtras: 0, gastosPersonales: 0, intereses: 0
      };
    }
    
    filteredData.forEach(row => {
      const m = row.mesNum;
      if (!monthly[m]) return;
      const tipo = row.Tipo;
      const monto = row.ventasImp;
      
      if (tipo === 'VENTAS') {
        monthly[m].ventasImp += monto;
        monthly[m].ventasBcv += row.ventasBcv;
      } else if (tipo === 'COSTOS VTA') {
        monthly[m].costoVenta += monto;
      } else if (tipo === 'GASTOS TIENDA') {
        monthly[m].gastosTienda += monto;
      } else if (tipo === 'GASTOS EXTRAS') {
        monthly[m].gastosExtras += monto;
      } else if (tipo === 'GASTOS PERSONALES') {
        monthly[m].gastosPersonales += monto;
      } else if (tipo === 'INTERESES') {
        monthly[m].intereses += monto;
      }
    });
    
    return Object.values(monthly).sort((a,b) => a.mesNum - b.mesNum);
  }

  function calculateTotals(monthlyData) {
    let totalSales = 0, totalBcv = 0, totalCost = 0, totalStoreExpenses = 0;
    let totalExtra = 0, totalPersonal = 0, totalInterest = 0;
    
    monthlyData.forEach(m => {
      totalSales += m.ventasImp;
      totalBcv += m.ventasBcv;
      totalCost += m.costoVenta;
      totalStoreExpenses += m.gastosTienda;
      totalExtra += m.gastosExtras;
      totalPersonal += m.gastosPersonales;
      totalInterest += m.intereses;
    });
    
    const grossProfit = totalSales - totalCost;
    const grossMarginPct = totalSales > 0 ? (grossProfit / totalSales) * 100 : 0;
    const operatingProfit = grossProfit - totalStoreExpenses;
    const otherExpenses = totalExtra + totalPersonal + totalInterest;
    const netProfit = operatingProfit - otherExpenses;
    const netMarginPct = totalSales > 0 ? (netProfit / totalSales) * 100 : 0;
    
    return { totalSales, totalBcv, totalCost, totalStoreExpenses, grossProfit, grossMarginPct,
             operatingProfit, otherExpenses, netProfit, netMarginPct, totalExtra, totalPersonal, totalInterest };
  }

  function updateKPIs(totals) {
    document.getElementById('kpi-totalSales').textContent = formatterUSD.format(totals.totalSales);
    document.getElementById('kpi-totalBcv').textContent = formatterUSD.format(totals.totalBcv);
    document.getElementById('kpi-totalCost').textContent = formatterUSD.format(totals.totalCost);
    document.getElementById('kpi-grossMarginPct').textContent = totals.grossMarginPct.toFixed(1) + '%';
    document.getElementById('kpi-grossProfit').textContent = formatterUSD.format(totals.grossProfit);
    document.getElementById('kpi-storeExpenses').textContent = formatterUSD.format(totals.totalStoreExpenses);
    document.getElementById('kpi-operatingProfit').textContent = formatterUSD.format(totals.operatingProfit);
    document.getElementById('kpi-otherExpenses').textContent = formatterUSD.format(totals.otherExpenses);
    document.getElementById('kpi-netProfit').textContent = formatterUSD.format(totals.netProfit);
    
    document.getElementById('detail-extraExpenses').textContent = formatterUSD.format(totals.totalExtra);
    document.getElementById('detail-personalExpenses').textContent = formatterUSD.format(totals.totalPersonal);
    document.getElementById('detail-interestExpenses').textContent = formatterUSD.format(totals.totalInterest);
  }

  function renderDetailTable(monthlyData, totals) {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';
    
    monthlyData.forEach(m => {
      const grossProfit = m.ventasImp - m.costoVenta;
      const grossMargin = m.ventasImp > 0 ? (grossProfit / m.ventasImp) * 100 : 0;
      const operatingProfit = grossProfit - m.gastosTienda;
      const otherExpenses = m.gastosExtras + m.gastosPersonales + m.intereses;
      const netProfit = operatingProfit - otherExpenses;
      const netMargin = m.ventasImp > 0 ? (netProfit / m.ventasImp) * 100 : 0;
      
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="font-bold">${m.mesNombre}</td>
        <td class="text-right font-semibold">${formatterUSD.format(m.ventasImp)}</td>
        <td class="text-right text-slate-600">${formatterUSD.format(m.ventasBcv)}</td>
        <td class="text-right">${formatterUSD.format(m.costoVenta)}</td>
        <td class="text-right ${grossProfit >= 0 ? 'positive' : 'negative'}">${formatterUSD.format(grossProfit)}</td>
        <td class="text-right ${grossMargin >= 0 ? 'positive' : 'negative'}">${grossMargin.toFixed(1)}%</td>
        <td class="text-right">${formatterUSD.format(m.gastosTienda)}</td>
        <td class="text-right ${operatingProfit >= 0 ? 'positive' : 'negative'}">${formatterUSD.format(operatingProfit)}</td>
        <td class="text-right">${formatterUSD.format(otherExpenses)}</td>
        <td class="text-right font-bold ${netProfit >= 0 ? 'text-emerald-600' : 'text-red-600'}">${formatterUSD.format(netProfit)}</td>
        <td class="text-right ${netMargin >= 0 ? 'positive' : 'negative'}">${netMargin.toFixed(1)}%</td>
      `;
      tbody.appendChild(tr);
    });
  }

  function initLineChart(monthlyData) {
    const canvas = document.getElementById('lineChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (lineChartInstance) lineChartInstance.destroy();
    
    const labels = monthlyData.map(m => m.mesNombre);
    const salesData = monthlyData.map(m => m.ventasImp);
    const costData = monthlyData.map(m => m.costoVenta);
    
    lineChartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { label: 'Ventas IMP ($)', data: salesData, borderColor: '#D32F2F', backgroundColor: 'rgba(211,47,47,0.1)', fill: true, tension: 0.3, borderWidth: 3 },
          { label: 'Costo Venta ($)', data: costData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.05)', fill: true, tension: 0.3, borderWidth: 2 }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { tooltip: { callbacks: { label: (ctx) => `${ctx.dataset.label}: ${formatterUSD.format(ctx.parsed.y)}` } } }, scales: { y: { beginAtZero: true, ticks: { callback: (value) => '$' + (value / 1000).toFixed(0) + 'k' } } } }
    });
  }

  function initProfitChart(monthlyData) {
    const canvas = document.getElementById('profitChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (profitChartInstance) profitChartInstance.destroy();
    
    const labels = monthlyData.map(m => m.mesNombre);
    const netProfits = monthlyData.map(m => {
      const grossProfit = m.ventasImp - m.costoVenta;
      const operatingProfit = grossProfit - m.gastosTienda;
      const otherExpenses = m.gastosExtras + m.gastosPersonales + m.intereses;
      return operatingProfit - otherExpenses;
    });
    
    profitChartInstance = new Chart(ctx, {
      type: 'bar',
      data: { labels: labels, datasets: [{ label: 'Utilidad Neta ($)', data: netProfits, backgroundColor: netProfits.map(p => p >= 0 ? '#10b981' : '#ef4444'), borderRadius: 6 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { tooltip: { callbacks: { label: (ctx) => formatterUSD.format(ctx.parsed.y) } } }, scales: { y: { ticks: { callback: (value) => formatterUSD.format(value) } } } }
    });
  }

  function updateCompanyUI() {
    document.querySelectorAll('.company-filter').forEach(btn => {
      const company = btn.dataset.company;
      if (selectedCompany === company) {
        btn.classList.remove('bg-slate-100', 'text-slate-600');
        btn.classList.add('bg-primary', 'text-white', 'shadow-md');
      } else {
        btn.classList.remove('bg-primary', 'text-white', 'shadow-md');
        btn.classList.add('bg-slate-100', 'text-slate-600');
      }
    });
    const allBtn = document.querySelector('.company-filter-all');
    if (selectedCompany === 'ALL') {
      allBtn.classList.remove('bg-slate-100', 'text-slate-600');
      allBtn.classList.add('bg-primary', 'text-white', 'shadow-md');
    } else {
      allBtn.classList.remove('bg-primary', 'text-white', 'shadow-md');
      allBtn.classList.add('bg-slate-100', 'text-slate-600');
    }
  }

  function renderDashboard() {
    const filtered = filterData();
    const monthlyData = aggregateMonthlyData(filtered);
    const totals = calculateTotals(monthlyData);
    
    updateKPIs(totals);
    renderDetailTable(monthlyData, totals);
    initLineChart(monthlyData);
    initProfitChart(monthlyData);
  }

  function setupEventListeners() {
    document.querySelectorAll('.company-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedCompany = btn.dataset.company;
        updateCompanyUI();
        renderDashboard();
      });
    });
    
    document.querySelector('.company-filter-all')?.addEventListener('click', () => {
      selectedCompany = 'ALL';
      updateCompanyUI();
      renderDashboard();
    });
    
    document.getElementById('btnApplyMonthFilter')?.addEventListener('click', () => {
      const start = parseInt(document.getElementById('monthStart').value);
      const end = parseInt(document.getElementById('monthEnd').value);
      if (start <= end) {
        monthStartFilter = start;
        monthEndFilter = end;
        renderDashboard();
      } else {
        alert('El mes "Desde" debe ser menor o igual al mes "Hasta"');
      }
    });
    
    document.getElementById('btnClearMonthFilter')?.addEventListener('click', () => {
      document.getElementById('monthStart').value = '1';
      document.getElementById('monthEnd').value = '12';
      monthStartFilter = 1;
      monthEndFilter = 12;
      renderDashboard();
    });
  }

  function init() {
    setupEventListeners();
    loadAndProcessData();
  }
  
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
